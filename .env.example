# ── AWS Credentials ────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_REGION=us-east-1

# ── Amazon Nova model IDs (Bedrock) ────────────────────────────────────────────
# Defaults are set in config.py — only override if needed.
# NOVA_LITE_MODEL_ID=amazon.nova-lite-v1:0
# NOVA_PRO_MODEL_ID=amazon.nova-pro-v1:0
# NOVA_SONIC_MODEL_ID=amazon.nova-sonic-v1:0

# ── Audio Transcription ────────────────────────────────────────────────────────
USE_AWS_TRANSCRIBE=true
# AWS_S3_TRANSCRIBE_BUCKET=your-s3-bucket-name   # required when USE_AWS_TRANSCRIBE=true
# OPENAI_API_KEY=sk-...                           # required when USE_AWS_TRANSCRIBE=false
# WHISPER_MODEL=whisper-1

# ── Voice / Sonic ──────────────────────────────────────────────────────────────
# SONIC_VOICE_ID=tiffany        # options: tiffany | matthew | amy

# ── Server ports ───────────────────────────────────────────────────────────────
# MCP_PORT=9090
# API_PORT=8080

# ── Observability (optional) ───────────────────────────────────────────────────
# OPIK_API_KEY=
# OPIK_WORKSPACE=default
# OPIK_PROJECT=video-rag
